NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Optional: override the site origin for auth email redirects.
# Falls back to the request origin header, then http://localhost:3000.
# On Vercel, set this to your production URL (e.g. https://lendfolio.vercel.app).
# NEXT_PUBLIC_SITE_URL=https://your-production-url

# Server-only keys are intentionally omitted.
# Never expose Supabase service role keys in NEXT_PUBLIC_* variables.

# Optional server-only AI key for borrower assistant polishing and scoped fallback.
# Prefer GEMINI_API_KEY. GOOGLE_API_KEY is also supported as a fallback name.
# Do not use NEXT_PUBLIC_GEMINI_API_KEY.
# Leave empty to use the built-in rule-based assistant only.
GEMINI_API_KEY=
# or GOOGLE_API_KEY=
